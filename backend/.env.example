# ─── NeuralChat Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to source control.

# ─── Provider Selection ───────────────────────────────────────────────────────
# Options: 'anthropic' (default) or 'openai'
PROVIDER=anthropic

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (default: claude-opus-4-6)
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-6

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model (default: gpt-4o)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# ─── Server Config ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Maximum tokens in the AI response
MAX_TOKENS=1024

# CORS: restrict to your frontend URL in production
# ALLOWED_ORIGIN=https://yourdomain.com

# ─── System Prompt (optional override) ───────────────────────────────────────
# SYSTEM_PROMPT=You are a helpful AI assistant.
